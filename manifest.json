{
  "manifest_version": 3,
  "name": "Stockfish Continue to Play",
  "version": "3.0.0",
  "description": "After a game ends on Chess.com, continue the position vs Stockfish AI on the same page. One click, automatic.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "*://*.chess.com/*"
  ],
  "background": {
    "service_worker": "service-worker.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.chess.com/game/*",
        "*://*.chess.com/play/*"
      ],
      "js": ["lib/chess-core.js", "lib/chess-dom.js", "content_chesscom.js"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["stockfish.js"],
      "matches": ["*://*.chess.com/*"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  }
}
