{
  "manifest_version": 3,
  "name": "Stockfish Continue to Play",
  "version": "2.0.7",
  "description": "After your opponent resigns, disconnects, or times out on Chess.com/Lichess, continue the game vs Stockfish. One click, automatic.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "*://*.chess.com/*",
    "*://*.lichess.org/*"
  ],
  "background": {
    "service_worker": "service-worker.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.chess.com/game/*",
        "*://*.chess.com/play/*"
      ],
      "js": ["lib/chess-utils.js", "content_chesscom.js"],
      "run_at": "document_end"
    },
    {
      "matches": ["*://*.lichess.org/*"],
      "js": ["lib/lichess-utils.js", "content_lichess.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["stockfish.js"],
      "matches": ["*://*.chess.com/*", "*://*.lichess.org/*"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  }
}
